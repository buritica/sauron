# Sauron gitignore

# Data directories - contains persistent state
data/

# Environment variables with secrets
.env

# Alertmanager → ca webhook bearer token (mounted into the container)
config/alertmanager/webhook-secret

# macOS
.DS_Store

# IDE
.vscode/
.idea/
*.swp
*.swo
.claude/

# Slack incoming webhook URL for alertmanager (mounted into the container)
config/alertmanager/slack-webhook-url
