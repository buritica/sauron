            "type": "loki",
            "uid": "P8E80F9AEF21F6940"
          },
          "expr": "sum by (level_label) (count_over_time({job=\"botsito\"} | json | __error__=\"\" | level >= $level | label_format level_label=`{{ if eq .level \"20\" }}debug{{ else if eq .level \"30\" }}info{{ else if eq .level \"40\" }}warn{{ else if eq .level \"50\" }}error{{ else }}unknown{{ end }}` [1m]))",
          "legendFormat": "{{level_label}}",
          "refId": "A"
        }
      ],
      "title": "Log Rate by Level",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
