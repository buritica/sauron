{
  "title": "Logs",
  "uid": "botsito-logs",
  "tags": [
    "botsito",
    "logs"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "level",
        "label": "Level",
        "type": "custom",
        "query": "all : 0,debug : 20,info : 30,warn : 40,error : 50",
        "current": {
          "text": "all",
          "value": "0"
        },
        "includeAll": false,
        "multi": false,
        "hide": 0
      },
      {
        "name": "module_filter",
        "label": "Module",
        "type": "textbox",
        "current": {
          "text": ".*",
          "value": ".*"
        },
        "query": ".*",
        "hide": 0
      },
      {
        "name": "channel",
        "label": "Channel",
        "type": "textbox",
        "current": {
          "text": ".*",
          "value": ".*"
        },
        "query": ".*",
        "hide": 0
      },
      {
        "name": "search",
        "label": "Search",
        "type": "textbox",
        "current": {
          "text": "",
          "value": ""
        },
        "query": "",
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 10,
      "title": "Log Volume",
      "type": "stat",
      "gridPos": {
        "h": 3,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "P8E80F9AEF21F6940"
          },
          "expr": "sum(count_over_time({app=\"ca\"} | json | __error__=\"\" | level >= $level | module =~ `$module_filter` | channelId =~ `$channel` [$__range]))",
          "instant": true
        }
      ]
    },
    {
      "id": 11,
      "title": "Errors",
      "type": "stat",
      "gridPos": {
        "h": 3,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "P8E80F9AEF21F6940"
          },
          "expr": "sum(count_over_time({app=\"ca\"} | json | __error__=\"\" | level >= 50 | module =~ `$module_filter` | channelId =~ `$channel` [$__range]))",
          "instant": true
        }
      ]
    },
    {
      "id": 12,
      "title": "Warnings",
      "type": "stat",
      "gridPos": {
        "h": 3,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "P8E80F9AEF21F6940"
          },
          "expr": "sum(count_over_time({app=\"ca\"} | json | __error__=\"\" | level >= 40 | level < 50 | module =~ `$module_filter` | channelId =~ `$channel` [$__range]))",
          "instant": true
        }
      ]
    },
    {
      "id": 1,
      "title": "Log Rate by Level",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 3
      },
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "debug"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "purple"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "info"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "warn"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "error"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "sum"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "P8E80F9AEF21F6940"
          },
          "expr": "sum by (level_label) (count_over_time({app=\"ca\"} | json | __error__=\"\" | level >= $level | module =~ `$module_filter` | channelId =~ `$channel` | label_format level_label=`{{ if eq .level \"20\" }}debug{{ else if eq .level \"30\" }}info{{ else if eq .level \"40\" }}warn{{ else if eq .level \"50\" }}error{{ else }}unknown{{ end }}` [$__interval]))",
          "legendFormat": "{{level_label}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Formatted logs",
      "type": "logs",
      "gridPos": {
        "h": 25,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "P8E80F9AEF21F6940"
          },
          "expr": "{app=\"ca\"} | json | __error__=`` | level >= $level | module =~ `$module_filter` | channelId =~ `$channel` | label_format level=`{{ if eq .level \"20\" }}debug{{ else if eq .level \"30\" }}info{{ else if eq .level \"40\" }}warn{{ else if eq .level \"50\" }}error{{ else }}unknown{{ end }}` | line_format `{{ if eq .level \"error\" }}❌{{ else if eq .level \"warn\" }}⚠️{{ else if eq .level \"info\" }}ℹ️{{ else if eq .level \"debug\" }}💬{{ else }}  {{ end }} [{{ .module }}] {{ .msg }}{{ if .config }} [{{ .config }}]{{ end }}{{ if .channelId }}{{ if not .config }} channel={{ .channelId }}{{ end }}{{ end }}{{ if .elapsedMs }} took={{ .elapsedMs }}ms{{ end }}{{ if .outcome }} outcome={{ .outcome }}{{ end }}{{ if .model }} model={{ .model }}{{ end }}{{ if .cost }} cost=${{ .cost }}{{ end }}{{ if .agent }} agent={{ .agent }}{{ end }}{{ if .err_message }} err={{ .err_message }}{{ end }}{{ if .traceId }} trace={{ .traceId }}{{ end }}` |~ \"(?i)$search\"",
          "maxLines": 500
        }
      ]
    },
    {
      "id": 20,
      "title": "Recent Errors",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "collapsed": true,
      "panels": [
        {
          "id": 21,
          "title": "Error Logs",
          "type": "logs",
          "gridPos": {
            "h": 10,
            "w": 24,
            "x": 0,
            "y": 35
          },
          "datasource": {
            "type": "loki",
            "uid": "P8E80F9AEF21F6940"
          },
          "options": {
            "showTime": true,
            "showLabels": false,
            "wrapLogMessage": true,
            "enableLogDetails": true,
            "sortOrder": "Descending"
          },
          "targets": [
            {
              "refId": "A",
              "datasource": {
                "type": "loki",
                "uid": "P8E80F9AEF21F6940"
              },
              "expr": "{app=\"ca\"} | json | __error__=`` | level >= 50 | module =~ `$module_filter` | channelId =~ `$channel` | line_format `❌ [{{ .module }}] {{ .msg }}{{ if .config }} [{{ .config }}]{{ end }}{{ if .channelId }}{{ if not .config }} channel={{ .channelId }}{{ end }}{{ end }}{{ if .err_message }} err={{ .err_message }}{{ end }}{{ if .traceId }} trace={{ .traceId }}{{ end }}` |~ \"(?i)$search\"",
              "maxLines": 200
            }
          ]
        }
      ]
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  }
}
