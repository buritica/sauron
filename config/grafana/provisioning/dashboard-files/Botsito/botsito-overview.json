{
  "title": "Overview",
  "uid": "botsito-overview",
  "tags": [
    "botsito"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "title": "Status",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "range",
              "options": {
                "from": 1,
                "to": 999999,
                "result": {
                  "text": "UP",
                  "color": "green"
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 0,
                "to": 0,
                "result": {
                  "text": "DOWN",
                  "color": "red"
                }
              }
            }
          ],
          "noValue": "DOWN",
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki"
          },
          "expr": "count_over_time({app=\"botsito\"}[30m])",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "title": "Messages (24h)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 4,
        "y": 0
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(increase(botsito_messages_total[24h]))",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 3,
      "title": "Success Rate (24h)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 9,
        "y": 0
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(increase(botsito_messages_total{outcome=\"success\"}[24h])) / sum(increase(botsito_messages_total[24h])) * 100"
        }
      ]
    },
    {
      "id": 4,
      "title": "Errors (24h)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 14,
        "y": 0
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(increase(botsito_messages_total{outcome=\"error\"}[24h]))"
        }
      ]
    },
    {
      "id": 5,
      "title": "Avg Query Duration",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 19,
        "y": 0
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "noValue": "—"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(rate(botsito_query_duration_ms_sum[1h])) / (sum(rate(botsito_query_duration_ms_count[1h])) > 0)"
        }
      ]
    },
    {
      "id": 6,
      "title": "Messages / hour",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "success"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "error"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "command"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "skipped"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "text"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "unauthorized"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum by (outcome) (increase(botsito_messages_total[1h]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Query Duration (p50 / p95)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus"
          },
          "expr": "histogram_quantile(0.5, sum by (le) (rate(botsito_query_duration_ms_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(botsito_query_duration_ms_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 9,
      "title": "Compaction Runs",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum by (outcome) (increase(botsito_compaction_runs_total[1h]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 12,
      "title": "Query Outcomes / hour",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "success"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "error"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "timeout"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "background"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "rejected"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "purple"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum by (outcome) (increase(botsito_query_outcome_total[1h]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 14,
      "title": "Slowest Queries (24h)",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "loki"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Time"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 180
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "elapsedMs"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              },
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "outcome"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "channelId"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 200
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "elapsedMs",
            "desc": true
          }
        ]
      },
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "Line",
            "format": "json",
            "jsonPaths": [
              {
                "path": "channelId",
                "alias": "channelId"
              },
              {
                "path": "elapsedMs",
                "alias": "elapsedMs"
              },
              {
                "path": "outcome",
                "alias": "outcome"
              },
              {
                "path": "senderName",
                "alias": "sender"
              },
              {
                "path": "traceId",
                "alias": "traceId"
              }
            ],
            "keepTime": false
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "labels": true,
              "id": true,
              "tsNs": true,
              "traceId": true,
              "time": true,
              "pid": true,
              "hostname": true,
              "name": true,
              "module": true,
              "msg": true,
              "level": true
            },
            "indexByName": {
              "Time": 0,
              "elapsedMs": 1,
              "outcome": 2,
              "sender": 3,
              "channelId": 4,
              "traceId": 5
            }
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki"
          },
          "expr": "{app=\"botsito\"} | json | __error__=`` | msg=`Query ended` | elapsedMs > 30000",
          "maxLines": 100
        }
      ]
    },
    {
      "id": 8,
      "title": "Recent Errors",
      "type": "logs",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "datasource": {
        "type": "loki"
      },
      "options": {
        "dedupStrategy": "none",
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki"
          },
          "expr": "{app=\"botsito\"} | json | __error__=`` | level >= 50 | line_format `❌ [{{ .module }}] {{ .msg }}{{ if .config }} [{{ .config }}]{{ end }}{{ if .channelId }}{{ if not .config }} channel={{ .channelId }}{{ end }}{{ end }}{{ if .elapsedMs }} took={{ .elapsedMs }}ms{{ end }}{{ if .outcome }} outcome={{ .outcome }}{{ end }}{{ if .model }} model={{ .model }}{{ end }}{{ if .cost }} cost=${{ .cost }}{{ end }}{{ if .agent }} agent={{ .agent }}{{ end }}{{ if .err_message }} err={{ .err_message }}{{ end }}{{ if .traceId }} trace={{ .traceId }}{{ end }}`",
          "maxLines": 100
        }
      ]
    },
    {
      "id": 22,
      "title": "Cache Hit Rate (1h)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 40
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "noValue": "—",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 30
              },
              {
                "color": "green",
                "value": 60
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(rate(botsito_cache_read_tokens_total[1h])) / (sum(rate(botsito_cache_read_tokens_total[1h])) + sum(rate(botsito_cache_creation_tokens_total[1h])) + sum(rate(botsito_tokens_input_total[1h]))) * 100"
        }
      ]
    },
    {
      "id": 23,
      "title": "Cost / hour",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 40
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 3,
          "noValue": "—"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(rate(botsito_cost_usd_total[1h])) * 3600"
        }
      ]
    },
    {
      "id": 24,
