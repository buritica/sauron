            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum by (outcome) (increase(botsito_messages_total{channel=~\"$channel\"}[1h]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Errors (24h)",
      "type": "stat",
      "description": "Messages with outcome=error over the last 24 hours.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "decimals": 0,
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(increase(botsito_messages_total{channel=~\"$channel\", outcome=\"error\"}[24h]))"
        }
      ]
    },
    {
      "id": 300,
      "type": "row",
      "title": "Latency",
      "collapsed": true,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "panels": [
        {
          "id": 5,
          "title": "Avg Query Duration (1h)",
          "type": "stat",
          "description": "Average SDK query duration over the last hour.",
          "gridPos": {
            "h": 4,
            "w": 6,
            "x": 0,
            "y": 19
          },
          "datasource": {
            "type": "prometheus"
          },
          "fieldConfig": {
            "defaults": {
              "unit": "ms",
              "decimals": 0,
              "min": 0,
              "noValue": "—"
            }
          },
          "options": {
            "colorMode": "value",
            "graphMode": "area",
            "reduceOptions": {
              "calcs": [
                "lastNotNull"
              ]
            }
          },
          "targets": [
            {
              "refId": "A",
              "datasource": {
                "type": "prometheus"
              },
              "expr": "sum(rate(botsito_query_duration_ms_sum{channel=~\"$channel\"}[1h])) / (sum(rate(botsito_query_duration_ms_count{channel=~\"$channel\"}[1h])) > 0)"
            }
          ]
        },
        {
          "id": 7,
          "title": "Query Duration (p50 / p95)",
          "type": "timeseries",
          "description": "Agent SDK query latency percentiles over a 5-minute rate window.",
          "gridPos": {
            "h": 8,
            "w": 18,
            "x": 6,
            "y": 19
          },
          "datasource": {
            "type": "prometheus"
          },
          "fieldConfig": {
            "defaults": {
              "unit": "ms",
              "min": 0,
              "decimals": 0,
              "color": {
                "mode": "palette-classic"
              },
              "custom": {
                "lineWidth": 1,
                "fillOpacity": 10
              }
            }
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": [
                "mean",
                "max"
              ]
            },
            "tooltip": {
              "mode": "multi"
            }
          },
          "targets": [
            {
              "refId": "A",
              "datasource": {
                "type": "prometheus"
              },
              "expr": "histogram_quantile(0.5, sum by (le) (rate(botsito_query_duration_ms_bucket{channel=~\"$channel\"}[5m])))",
              "legendFormat": "p50"
            },
            {
              "refId": "B",
              "datasource": {
                "type": "prometheus"
              },
              "expr": "histogram_quantile(0.95, sum by (le) (rate(botsito_query_duration_ms_bucket{channel=~\"$channel\"}[5m])))",
              "legendFormat": "p95"
            }
          ]
        },
        {
          "id": 14,
          "title": "Slowest Queries (24h)",
          "type": "table",
          "description": "Queries whose elapsedMs exceeded 30 s in the last 24 hours, sorted slowest-first.",
          "gridPos": {
            "h": 8,
            "w": 24,
            "x": 0,
            "y": 27
          },
          "datasource": {
            "type": "loki"
          },
          "fieldConfig": {
            "defaults": {},
            "overrides": [
              {
                "matcher": {
                  "id": "byName",
                  "options": "Time"
                },
                "properties": [
                  {
                    "id": "custom.width",
                    "value": 180
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byName",
                  "options": "elapsedMs"
                },
                "properties": [
                  {
                    "id": "unit",
                    "value": "ms"
                  },
                  {
                    "id": "custom.width",
                    "value": 120
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byName",
                  "options": "outcome"
                },
                "properties": [
                  {
                    "id": "custom.width",
                    "value": 100
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byName",
                  "options": "channelId"
                },
                "properties": [
                  {
                    "id": "custom.width",
                    "value": 200
                  }
                ]
              }
            ]
          },
          "options": {
            "showHeader": true,
            "sortBy": [
              {
                "displayName": "elapsedMs",
                "desc": true
              }
            ]
          },
          "transformations": [
            {
              "id": "extractFields",
              "options": {
                "source": "Line",
                "format": "json",
                "jsonPaths": [
                  {
                    "path": "channelId",
                    "alias": "channelId"
                  },
                  {
                    "path": "elapsedMs",
                    "alias": "elapsedMs"
                  },
                  {
                    "path": "outcome",
                    "alias": "outcome"
                  },
                  {
                    "path": "senderName",
                    "alias": "sender"
                  },
                  {
                    "path": "traceId",
                    "alias": "traceId"
                  }
                ],
                "keepTime": false
              }
            },
            {
              "id": "organize",
              "options": {
                "excludeByName": {
                  "Line": true,
                  "labels": true,
                  "id": true,
                  "tsNs": true,
                  "traceId": true,
                  "time": true,
                  "pid": true,
                  "hostname": true,
                  "name": true,
                  "module": true,
                  "msg": true,
                  "level": true
                },
                "indexByName": {
                  "Time": 0,
                  "elapsedMs": 1,
                  "outcome": 2,
                  "sender": 3,
                  "channelId": 4,
                  "traceId": 5
                }
              }
            }
          ],
          "targets": [
            {
              "refId": "A",
              "datasource": {
                "type": "loki"
              },
              "expr": "{app=\"botsito\"} | json | __error__=`` | msg=`Query ended` | elapsedMs > 30000",
              "maxLines": 100
            }
          ]
        }
      ]
    },
    {
      "id": 400,
      "type": "row",
      "title": "Economics",
      "collapsed": true,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 19
      },
      "panels": [
        {
