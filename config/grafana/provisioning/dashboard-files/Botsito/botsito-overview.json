{
  "title": "Overview",
  "uid": "botsito-overview",
  "tags": [
    "botsito"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "channel",
        "label": "Channel",
        "type": "query",
        "datasource": {
          "type": "prometheus"
        },
        "query": {
          "refId": "channel",
          "query": "label_values(botsito_messages_total, channel)"
        },
        "definition": "label_values(botsito_messages_total, channel)",
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2,
        "sort": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 1,
      "title": "Status",
      "type": "stat",
      "description": "Liveness heuristic — count of log lines in the last 30 minutes. Prometheus scrapes OTLP push from botsito, so there is no up{job=\"botsito\"} series; Loki activity is the best available signal.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "loki"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "range",
              "options": {
                "from": 1,
                "to": 999999,
                "result": {
                  "text": "UP",
                  "color": "green"
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 0,
                "to": 0,
                "result": {
                  "text": "DOWN",
                  "color": "red"
                }
              }
            }
          ],
          "noValue": "DOWN",
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki"
          },
          "expr": "count_over_time({app=\"botsito\"}[30m])",
          "instant": true
        }
      ]
    },
    {
      "id": 12,
      "title": "Query Outcomes / hour",
      "type": "timeseries",
      "description": "Agent SDK query outcomes per hour (success, error, timeout, background, rejected).",
      "gridPos": {
        "h": 8,
        "w": 18,
        "x": 6,
        "y": 1
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "decimals": 0,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "success"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "error"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "timeout"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "background"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "skipped"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "text"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum by (outcome) (increase(botsito_query_outcome_total{channel=~\"$channel\"}[1h]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 200,
      "type": "row",
      "title": "Traffic",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "panels": []
    },
    {
      "id": 2,
      "title": "Messages (24h)",
      "type": "stat",
      "description": "Total inbound messages processed in the last 24 hours.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "decimals": 0,
          "noValue": "0"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(increase(botsito_messages_total{channel=~\"$channel\"}[24h]))",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 3,
      "title": "Success Rate (24h)",
      "type": "stat",
      "description": "Share of messages with outcome=success over the last 24 hours. Red <95%, yellow 95–99%, green >=99%.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 10
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 95
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus"
          },
          "expr": "sum(increase(botsito_messages_total{channel=~\"$channel\", outcome=\"success\"}[24h])) / sum(increase(botsito_messages_total{channel=~\"$channel\"}[24h])) * 100"
        }
      ]
    },
    {
      "id": 6,
      "title": "Messages / hour",
      "type": "timeseries",
      "description": "Inbound messages grouped by outcome, per hour.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "datasource": {
        "type": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "decimals": 0,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
