        {
          "id": 22,
          "title": "Cache Hit Rate (1h)",
          "type": "stat",
          "description": "Share of input tokens served from prompt cache over the last hour. Red <30%, yellow 30–50%, green >=50% (issue #619 criteria).",
          "gridPos": {
            "h": 4,
            "w": 6,
            "x": 6,
            "y": 20
          },
          "datasource": {
            "type": "prometheus"
          },
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "decimals": 2,
              "min": 0,
              "max": 100,
              "noValue": "—",
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "red",
                    "value": null
                  },
                  {
                    "color": "yellow",
                    "value": 30
                  },
                  {
                    "color": "green",
                    "value": 50
                  }
                ]
              }
            }
          },
          "options": {
            "colorMode": "value",
            "graphMode": "area",
            "reduceOptions": {
              "calcs": [
                "lastNotNull"
              ]
            }
          },
          "targets": [
            {
              "refId": "A",
              "datasource": {
                "type": "prometheus"
              },
              "expr": "sum(rate(botsito_cache_read_tokens_total{channel_id=~\"$channel\"}[1h])) / (sum(rate(botsito_cache_read_tokens_total{channel_id=~\"$channel\"}[1h])) + sum(rate(botsito_cache_creation_tokens_total{channel_id=~\"$channel\"}[1h])) + sum(rate(botsito_tokens_input_total{channel_id=~\"$channel\"}[1h]))) * 100"
            }
          ]
        },
        {
          "id": 27,
          "title": "Fallback Engaged (24h)",
          "type": "stat",
          "description": "Queries where the SDK's native fallbackModel swapped to a second model mid-request (added in botsito #647).",
          "gridPos": {
            "h": 4,
            "w": 6,
            "x": 12,
            "y": 20
          },
          "datasource": {
            "type": "prometheus"
          },
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "min": 0,
              "decimals": 0,
              "noValue": "0",
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "green",
                    "value": null
                  },
                  {
                    "color": "orange",
