                "steps": [
                  {
                    "color": "green",
                    "value": null
                  },
                  {
                    "color": "orange",
                    "value": 1
                  },
                  {
                    "color": "red",
                    "value": 5
                  }
                ]
              }
            }
          },
          "options": {
            "colorMode": "value",
            "graphMode": "area",
            "reduceOptions": {
              "calcs": [
                "lastNotNull"
              ]
            }
          },
          "targets": [
            {
              "refId": "A",
              "datasource": {
                "type": "prometheus",
                "uid": "PBFA97CFB590B2093"
              },
              "expr": "sum(increase(botsito_extraction_failures_total[1h]))"
            }
          ]
        },
        {
          "id": 31,
          "title": "Extraction Failure Rate",
          "type": "timeseries",
          "gridPos": {
            "h": 8,
            "w": 18,
            "x": 6,
            "y": 28
          },
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "min": 0,
              "decimals": 0,
              "color": {
                "mode": "palette-classic"
              },
              "custom": {
                "lineWidth": 1,
                "fillOpacity": 10
              }
            }
          },
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": [
                "sum"
              ]
            },
            "tooltip": {
              "mode": "multi"
            }
          },
          "targets": [
            {
              "refId": "A",
              "datasource": {
                "type": "prometheus",
                "uid": "PBFA97CFB590B2093"
              },
              "expr": "sum by (channel) (increase(botsito_extraction_failures_total[1h]))",
              "legendFormat": "{{channel}}"
            }
          ]
        }
      ]
    }
  ]
}
