                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*botsito\\.workflow$"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "super-light-blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*botsito\\.ingest\\.sdk_query$"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "light-green"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "sum by (span_name) (rate(traces_spanmetrics_calls_total{service=\"botsito\"}[5m]))",
          "legendFormat": "{{span_name}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Trace Search",
      "type": "table",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "tempo",
        "uid": "PE20A8C6A3B2F1D90"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "PE20A8C6A3B2F1D90"
          },
          "queryType": "traceql",
          "query": "{resource.service.name = \"botsito\"}",
          "limit": 30,
          "tableType": "traces"
        }
      ]
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  }
}
